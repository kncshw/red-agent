# vLLM / Gemma4 (abliterated)
VLLM_BASE_URL=http://your-vllm-host:8000/v1
VLLM_MODEL=gemma4-26B-abliterated
VLLM_API_KEY=sk-dummy-key
VLLM_TEMPERATURE=0
VLLM_VERIFY_SSL=false

# Kafka (same broker as bis-cspm)
KAFKA_HOST=your-kafka-host
KAFKA_PORT=9094
KAFKA_USERNAME=your-kafka-user
KAFKA_PASSWORD=your-kafka-password

# Kali sandbox server (FastAPI executor)
KALI_API_URL=http://your-kali-host:443
KALI_API_TOKEN=your-kali-api-token

# NetBox (asset owner enrichment)
NETBOX_API_URL=https://your-netbox
NETBOX_API_TOKEN=your-netbox-token
NETBOX_VERIFY_SSL=false

# Email escalation — sends to Teams channel via SMTP (fill in to enable)
EMAIL_SERVER=your-smtp-server
EMAIL_USERNAME=your-smtp-user
EMAIL_PASSWORD=your-smtp-password
EMAIL_RECIPIENTS=your-teams-channel@your-tenant.teams.ms
EMAIL_SMTP_PORT=587
EMAIL_USE_TLS=true

# FortiSOAR (disabled until verified)
ENABLE_FORTISOAR=false
FORTISOAR_URL=https://your-fortisoar
FORTISOAR_PUBLIC_KEY_FILE=/secrets/fsr.pub
FORTISOAR_PRIVATE_KEY_FILE=/secrets/fsr.priv
FORTISOAR_VERIFY_SSL=false

# Agent behaviour
MAX_TOOL_ROUNDS=6
CONCURRENT_IPS=3
KAFKA_TIME_WINDOW_HOURS=26
